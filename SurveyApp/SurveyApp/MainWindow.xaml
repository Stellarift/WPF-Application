<Window x:Class="SurveyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анкета пользователя" Height="600" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <TextBlock Grid.Row="0" Text="АНКЕТА ПОЛЬЗОВАТЕЛЯ" FontSize="24" 
                   FontWeight="Bold" HorizontalAlignment="Center" 
                   Foreground="#2C3E50" Margin="0,0,0,20"/>

        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <StackPanel Margin="10">

                
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ФИО:" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtFullName" Grid.Column="1" FontSize="16" Height="35" 
                                 ToolTip="Введите ваше полное имя"/>
                    </Grid>
                </Border>

                
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Возраст:" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="txtAge" FontSize="16" Width="80" Text="18" Margin="0,0,10,0"/>
                            <TextBlock Text="лет" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Пол:" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton x:Name="rbMale" Content="Мужской" FontSize="16" Margin="0,0,20,0" IsChecked="True" GroupName="Gender"/>
                            <RadioButton x:Name="rbFemale" Content="Женский" FontSize="16" GroupName="Gender"/>
                        </StackPanel>
                    </Grid>
                </Border>

                
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Город:" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cmbCity" Grid.Column="1" FontSize="16" Height="35" 
                                  ToolTip="Выберите город">
                            <ComboBoxItem Content="Москва" IsSelected="True"/>
                            <ComboBoxItem Content="Санкт-Петербург"/>
                            <ComboBoxItem Content="Новосибирск"/>
                            <ComboBoxItem Content="Екатеринбург"/>
                            <ComboBoxItem Content="Казань"/>
                            <ComboBoxItem Content="Нижний Новгород"/>
                            <ComboBoxItem Content="Красноярск"/>
                            <ComboBoxItem Content="Челябинск"/>
                            <ComboBoxItem Content="Уфа"/>
                            <ComboBoxItem Content="Самара"/>
                            <ComboBoxItem Content="Ростов-на-Дону"/>
                            <ComboBoxItem Content="Омск"/>
                            <ComboBoxItem Content="Краснодар"/>
                            <ComboBoxItem Content="Воронеж"/>
                            <ComboBoxItem Content="Пермь"/>
                            <ComboBoxItem Content="Волгоград"/>
                            <ComboBoxItem Content="Саратов"/>
                            <ComboBoxItem Content="Тюмень"/>
                            <ComboBoxItem Content="Тольятти"/>
                            <ComboBoxItem Content="Ижевск"/>
                            <ComboBoxItem Content="Барнаул"/>
                            <ComboBoxItem Content="Ульяновск"/>
                            <ComboBoxItem Content="Иркутск"/>
                            <ComboBoxItem Content="Хабаровск"/>
                            <ComboBoxItem Content="Ярославль"/>
                            <ComboBoxItem Content="Владивосток"/>
                        </ComboBox>
                    </Grid>
                </Border>

                
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Интересы:" FontSize="16" FontWeight="Bold" VerticalAlignment="Top" Margin="0,5,0,0"/>
                        <ListBox x:Name="lstInterests" Grid.Column="1" Height="100" 
                                 SelectionMode="Multiple" FontSize="14">
                            <ListBoxItem Content="Игры"/>
                            <ListBoxItem Content="Книги"/>
                            <ListBoxItem Content="Музыка"/>
                            <ListBoxItem Content="Кино"/>
                            <ListBoxItem Content="Спорт"/>
                            <ListBoxItem Content="Путешествия"/>
                            <ListBoxItem Content="Фотография"/>
                            <ListBoxItem Content="Программирование"/>
                            <ListBoxItem Content="Рисование"/>
                            <ListBoxItem Content="Кулинария"/>
                            <ListBoxItem Content="Настольные игры"/>
                            <ListBoxItem Content="Театр"/>
                        </ListBox>
                    </Grid>
                </Border>

                
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="О себе:" FontSize="16" FontWeight="Bold" VerticalAlignment="Top" Margin="0,5,0,0"/>
                        <TextBox x:Name="txtAbout" Grid.Column="1" FontSize="14" Height="80" 
                                 TextWrapping="Wrap" AcceptsReturn="True" 
                                 ToolTip="Расскажите немного о себе"/>
                    </Grid>
                </Border>

                
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <CheckBox x:Name="chkAgree" Content="Я согласен на обработку персональных данных" 
                              FontSize="14" Margin="0,5"/>
                </Border>

                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnShow" Content="ПОКАЗАТЬ РЕЗУЛЬТАТ" Width="250" Height="45" 
                            Margin="5" FontSize="16" FontWeight="Bold"
                            Background="#3498DB" Foreground="White" Click="btnShow_Click">
                        <Button.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="5" Opacity="0.3"/>
                        </Button.Effect>
                    </Button>
                    <Button x:Name="btnClear" Content="ОЧИСТИТЬ" Width="150" Height="45" 
                            Margin="5" FontSize="16" FontWeight="Bold"
                            Background="#E74C3C" Foreground="White" Click="btnClear_Click">
                        <Button.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="5" Opacity="0.3"/>
                        </Button.Effect>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        
        <Border Grid.Row="2" Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,10,0,0">
            <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="txtResult" FontSize="14" Foreground="White" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
