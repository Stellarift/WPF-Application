<Window x:Class="Game2048.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="2048" Height="570" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FAF8EF" KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="2048" FontSize="48" FontWeight="Bold" Foreground="#776E65" VerticalAlignment="Center"/>

            <Border Grid.Column="1" Background="#BBADA0" CornerRadius="6" Padding="12,6" Margin="0,0,8,0" VerticalAlignment="Center" MinWidth="75">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="СЧЕТ" FontSize="11" FontWeight="Bold" Foreground="#EEE4DA" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtScore" Text="0" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#BBADA0" CornerRadius="6" Padding="12,6" VerticalAlignment="Center" MinWidth="75">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="РЕКОРД" FontSize="11" FontWeight="Bold" Foreground="#EEE4DA" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtBest" Text="0" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="#BBADA0" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center" Height="360" Width="360">
            <Grid Width="340" Height="340" HorizontalAlignment="Center" VerticalAlignment="Center">
                <UniformGrid Rows="4" Columns="4" x:Name="BackgroundGrid"/>

                <Canvas x:Name="AnimationCanvas" Background="Transparent" IsHitTestVisible="False" Width="340" Height="340" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Button x:Name="btnNewGame" Content="Новая игра" Width="130" Height="40" 
                        Margin="6,0" Background="#8F7A66" Foreground="White" BorderThickness="0"
                        FontSize="15" FontWeight="Bold" Click="NewGame_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="btnReset" Content="Сброс" Width="100" Height="40" 
                        Margin="6,0" Background="#8F7A66" Foreground="White" BorderThickness="0"
                        FontSize="15" FontWeight="Bold" Click="Reset_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <TextBlock Grid.Row="1" Text="Управление: стрелки или WASD" 
                       FontSize="13" Foreground="#999999" FontWeight="Medium"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>