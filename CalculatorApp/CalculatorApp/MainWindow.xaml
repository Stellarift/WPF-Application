<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="500" Width="380" 
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="#2D2D2D">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="txtExpression" Grid.Row="0" 
                 FontSize="14" Height="35" TextAlignment="Right"
                 IsReadOnly="True" Background="#3D3D3D" Foreground="#CCCCCC"
                 BorderBrush="#555555" Margin="0,0,0,5" Padding="5" 
                 VerticalContentAlignment="Center"/>

        <TextBox x:Name="txtCurrent" Grid.Row="1" 
                 FontSize="36" Height="65" TextAlignment="Right"
                 IsReadOnly="True" FontWeight="Bold" Background="#3D3D3D" 
                 Foreground="White" BorderBrush="#555555" 
                 Margin="0,0,0,10" Padding="5" VerticalContentAlignment="Center"/>

        <Grid Grid.Row="2" Margin="0,5,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

          
            <Grid.Resources>
                <Style TargetType="Button">
                    <Setter Property="FontSize" Value="20"/>
                    <Setter Property="Margin" Value="3"/>
                    <Setter Property="Background" Value="#4D4D4D"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#666666"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#666666"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#888888"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Grid.Resources>

            
            <Button x:Name="btn7" Grid.Row="0" Grid.Column="0" Content="7" Click="Number_Click"/>
            <Button x:Name="btn8" Grid.Row="0" Grid.Column="1" Content="8" Click="Number_Click"/>
            <Button x:Name="btn9" Grid.Row="0" Grid.Column="2" Content="9" Click="Number_Click"/>
            <Button x:Name="btnDivide" Grid.Row="0" Grid.Column="3" Content="/" Background="#FF9500" Click="Operator_Click"/>

            
            <Button x:Name="btn4" Grid.Row="1" Grid.Column="0" Content="4" Click="Number_Click"/>
            <Button x:Name="btn5" Grid.Row="1" Grid.Column="1" Content="5" Click="Number_Click"/>
            <Button x:Name="btn6" Grid.Row="1" Grid.Column="2" Content="6" Click="Number_Click"/>
            <Button x:Name="btnMultiply" Grid.Row="1" Grid.Column="3" Content="*" Background="#FF9500" Click="Operator_Click"/>

            
            <Button x:Name="btn1" Grid.Row="2" Grid.Column="0" Content="1" Click="Number_Click"/>
            <Button x:Name="btn2" Grid.Row="2" Grid.Column="1" Content="2" Click="Number_Click"/>
            <Button x:Name="btn3" Grid.Row="2" Grid.Column="2" Content="3" Click="Number_Click"/>
            <Button x:Name="btnMinus" Grid.Row="2" Grid.Column="3" Content="-" Background="#FF9500" Click="Operator_Click"/>

            
            <Button x:Name="btn0" Grid.Row="3" Grid.Column="0" Content="0" Click="Number_Click"/>
            <Button x:Name="btnDot" Grid.Row="3" Grid.Column="1" Content="." Click="Dot_Click"/>
            <Button x:Name="btnCE" Grid.Row="3" Grid.Column="2" Content="CE" Background="#A52A2A" Click="CE_Click"/>
            <Button x:Name="btnPlus" Grid.Row="3" Grid.Column="3" Content="+" Background="#FF9500" Click="Operator_Click"/>

           
            <Button x:Name="btnC" Grid.Row="4" Grid.Column="0" Content="C" Background="#A52A2A" Click="C_Click"/>
            <Button x:Name="btnBack" Grid.Row="4" Grid.Column="1" Content="⌫" FontSize="18" Background="#A52A2A" Click="Back_Click"/>
            <Button x:Name="btnEqual" Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Content="=" Background="#228B22" Click="Equal_Click"/>
        </Grid>
    </Grid>
</Window>
